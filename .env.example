# Local DeepSeek via Ollama (matches requests + proxies=None pattern)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

AI_MODEL=deepseek-r1:7b
CHAT_MODEL=deepseek-r1:7b
REPORT_MODEL=deepseek-r1:7b

API_KEY=
# Corporate proxy for Supabase only — Ollama calls use proxies={"http": None, "https": None}
PROXY=
VERIFY_SSL=false
ENDPOINT=

# data.json is fetched automatically from ENDPOINT on startup when missing.

# CPU inference on company laptops: use long timeouts (seconds)
CHAT_CONNECT_TIMEOUT=15
CHAT_TIMEOUT=300
OLLAMA_TIMEOUT=600
OLLAMA_NUM_CTX=1024
OLLAMA_KEEP_ALIVE=30m
CHAT_MAX_TOKENS=512
OLLAMA_WARMUP=true
# Regenerate report.html after each chat (summary tables always; AI narrative if true)
REFRESH_REPORT_ON_CHAT=false
# When false, chat UI refreshes data via POST /api/data/refresh first (more reliable)
REFRESH_DATA_ON_CHAT=false
# When true (default), every chat message is sent to the LLM — no local shortcuts.
CHAT_FORCE_AI=true
# URL the chat panel calls (use your LAN IP when colleagues open the report remotely)
API_BASE_URL=http://10.77.32.120:8000

# Docker Compose: OLLAMA_BASE_URL=http://ollama:11434 (set in docker-compose.yml)
