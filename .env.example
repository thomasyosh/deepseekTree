# Local DeepSeek via Ollama (matches requests + proxies=None pattern)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

AI_MODEL=deepseek-r1:14b
CHAT_MODEL=deepseek-r1:14b
REPORT_MODEL=deepseek-r1:14b

API_KEY=
# Corporate proxy for Supabase only — Ollama calls use proxies={"http": None, "https": None}
PROXY=
VERIFY_SSL=false
ENDPOINT=

# data.json is fetched automatically from ENDPOINT on startup when missing.

# Ollama uses /api/chat with proxy bypass (not /v1 via cloud OpenAI).
# Test: curl.exe --noproxy "*" http://localhost:11434/api/tags
OLLAMA_TIMEOUT=180
OLLAMA_NUM_CTX=2048
CHAT_TIMEOUT=60
CHAT_MAX_TOKENS=256
API_BASE_URL=http://127.0.0.1:8000

# Docker Compose: OLLAMA_BASE_URL=http://ollama:11434 (set in docker-compose.yml)
