# Local DeepSeek via Ollama (OpenAI-compatible /v1 API — NOT ChatGPT cloud)
LLM_PROVIDER=ollama
AI_MODEL=deepseek-r1:7b
CHAT_MODEL=deepseek-r1:7b
REPORT_MODEL=deepseek-r1:7b
OLLAMA_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_API_KEY=ollama

# Optional: OpenAI hosted API instead (LLM_PROVIDER=cloud)
# LLM_PROVIDER=cloud
# OPENAI_API_KEY=sk-your-key-here

API_KEY=
# Corporate proxy. For Docker on Windows use host.docker.internal, e.g.:
# PROXY=http://host.docker.internal:8080
# For native Python/Ollama on the host, use your company proxy hostname, e.g.:
# PROXY=http://smoproxy:8080
PROXY=
# Set to false when a corporate proxy performs SSL inspection (MITM certificates).
VERIFY_SSL=false
ENDPOINT=

# data.json is fetched automatically from ENDPOINT on startup when missing.

# Native Python (no Docker) — Ollama must be installed and running locally:
# Do NOT use http://ollama:11434 unless you are inside docker-compose.
# Do NOT use http://localhost — company proxies often intercept it. Use 127.0.0.1.
#
# curl http://localhost:11434 may show company policy HTML (proxy), not Ollama.
# Valid test: curl.exe --noproxy "*" http://127.0.0.1:11434/api/tags
# Or run: scripts\start_server.ps1  and open /api/llm-health
OLLAMA_TIMEOUT=180
# Lower context uses less RAM (helpful if llama-server is killed / OOM). Default 2048.
OLLAMA_NUM_CTX=2048
CHAT_TIMEOUT=60
CHAT_MAX_TOKENS=256
API_BASE_URL=http://127.0.0.1:8000

# Docker Compose (see docker-compose.yml):
# - OLLAMA_OPENAI_BASE_URL=http://ollama:11434/v1 (set automatically)
# - Ollama x509 errors: copy company root CA to docker/certs/corporate-ca.crt, then:
#     docker compose build ollama
#     docker compose up
#
# Native `ollama pull` on Windows (outside Docker): install the company root CA in
# Windows Trusted Root store, or run:
#   set SSL_CERT_FILE=C:\path\to\company-root-ca.pem
#   ollama pull deepseek-r1:7b
#
# If ollama returns "llama-server process has terminated signal: killed":
# - Docker Desktop → Settings → Resources → Memory: set at least 8 GB (16 GB recommended)
# - deepseek-r1:7b needs ~6-8 GB RAM on CPU; avoid REPORT_MODEL=14b unless you have 16+ GB
# - docker-compose.yml sets shm_size=2gb for the Ollama container (required for llama.cpp)
