API_KEY=
# Corporate proxy for external APIs only (Ollama on localhost bypasses this).
PROXY=
# Set to false when a corporate proxy performs SSL inspection (MITM certificates).
VERIFY_SSL=false
ENDPOINT=

# data.json is fetched automatically from ENDPOINT on startup when missing.

# Default Ollama model (fallback if CHAT_MODEL / REPORT_MODEL are unset)
AI_MODEL=deepseek-r1:7b

# Fast model for /api/chat (interactive Q&A)
CHAT_MODEL=deepseek-r1:7b

# Slower model for one-time report narrative in report.html
REPORT_MODEL=deepseek-r1:14b

OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_TIMEOUT=180
CHAT_TIMEOUT=60
CHAT_MAX_TOKENS=256
API_BASE_URL=http://127.0.0.1:8000

# Docker Compose: Ollama runs as service "ollama" (set automatically in docker-compose.yml)
# OLLAMA_URL=http://ollama:11434/v1/chat/completions
#
# Docker build/run: proxy vars are cleared inside containers (see docker-compose.yml).
# If Supabase calls fail from Docker, point PROXY at the host gateway, e.g.:
# PROXY=http://host.docker.internal:8080
