API_KEY=
# Corporate proxy. For Docker on Windows use host.docker.internal, e.g.:
# PROXY=http://host.docker.internal:8080
# For native Python/Ollama on the host, use your company proxy hostname, e.g.:
# PROXY=http://smoproxy:8080
PROXY=
# Set to false when a corporate proxy performs SSL inspection (MITM certificates).
VERIFY_SSL=false
ENDPOINT=

# data.json is fetched automatically from ENDPOINT on startup when missing.

# Default Ollama model (fallback if CHAT_MODEL / REPORT_MODEL are unset)
AI_MODEL=deepseek-r1:7b

# Fast model for /api/chat (interactive Q&A)
CHAT_MODEL=deepseek-r1:7b

# Slower model for one-time report narrative in report.html
REPORT_MODEL=deepseek-r1:14b

OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_TIMEOUT=180
CHAT_TIMEOUT=60
CHAT_MAX_TOKENS=256
API_BASE_URL=http://127.0.0.1:8000

# Docker Compose (see docker-compose.yml):
# - OLLAMA_URL is set to http://ollama:11434/v1/chat/completions automatically
# - Ollama x509 errors: copy company root CA to docker/certs/corporate-ca.crt, then:
#     docker compose build ollama
#     docker compose up
#
# Native `ollama pull` on Windows (outside Docker): install the company root CA in
# Windows Trusted Root store, or run:
#   set SSL_CERT_FILE=C:\path\to\company-root-ca.pem
#   ollama pull deepseek-r1:7b
